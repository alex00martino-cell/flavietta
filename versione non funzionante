<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Calcolatore Orario di Uscita</title>
  <style>
    :root {
      --bg1: #ffe4ec;
      --bg2: #fff7fb;
      --card: rgba(255, 255, 255, 0.78);
      --text: #5a2a3a;
      --accent: #ff6fa1;
      --accent-dark: #e84d87;
      --shadow: 0 20px 45px rgba(232, 77, 135, 0.18);
      --border: rgba(255, 111, 161, 0.22);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background:
        radial-gradient(circle at top left, #ffd1e0 0%, transparent 30%),
        radial-gradient(circle at bottom right, #ffd9eb 0%, transparent 25%),
        linear-gradient(135deg, var(--bg1), var(--bg2));
      color: var(--text);
      padding: 24px;
      overflow: hidden;
    }

    .floating-hearts {
      position: fixed;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
    }

    .heart {
      position: absolute;
      font-size: 20px;
      opacity: 0.22;
      animation: floatUp linear infinite;
    }

    .heart:nth-child(1) { left: 10%; animation-duration: 12s; animation-delay: 0s; }
    .heart:nth-child(2) { left: 22%; animation-duration: 15s; animation-delay: 2s; }
    .heart:nth-child(3) { left: 38%; animation-duration: 13s; animation-delay: 1s; }
    .heart:nth-child(4) { left: 55%; animation-duration: 16s; animation-delay: 4s; }
    .heart:nth-child(5) { left: 70%; animation-duration: 14s; animation-delay: 3s; }
    .heart:nth-child(6) { left: 85%; animation-duration: 17s; animation-delay: 5s; }

    @keyframes floatUp {
      from {
        transform: translateY(110vh) scale(0.8);
        opacity: 0;
      }
      20% {
        opacity: 0.25;
      }
      to {
        transform: translateY(-15vh) scale(1.2);
        opacity: 0;
      }
    }

    .card {
      position: relative;
      width: 100%;
      max-width: 460px;
      background: var(--card);
      backdrop-filter: blur(16px);
      border: 1px solid var(--border);
      border-radius: 28px;
      padding: 32px 26px;
      box-shadow: var(--shadow);
      text-align: center;
      z-index: 1;
    }

    .badge {
      display: inline-block;
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(255, 111, 161, 0.14);
      color: var(--accent-dark);
      font-size: 0.9rem;
      font-weight: 700;
      margin-bottom: 16px;
    }

    h1 {
      font-size: clamp(1.8rem, 3vw, 2.4rem);
      line-height: 1.1;
      margin-bottom: 10px;
    }

    .subtitle {
      font-size: 1rem;
      color: #7a4a5b;
      margin-bottom: 28px;
    }

    .input-group {
      text-align: left;
      margin-bottom: 18px;
    }

    label {
      display: block;
      font-size: 0.95rem;
      font-weight: 700;
      margin-bottom: 8px;
    }

    input[type="time"] {
      width: 100%;
      padding: 16px 18px;
      border: 1.5px solid #f5b8cf;
      border-radius: 16px;
      font-size: 1.1rem;
      background: rgba(255,255,255,0.95);
      color: var(--text);
      outline: none;
      transition: 0.2s ease;
    }

    input[type="time"]:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 5px rgba(255, 111, 161, 0.14);
    }

    button {
      width: 100%;
      padding: 16px;
      border: none;
      border-radius: 16px;
      background: linear-gradient(135deg, var(--accent), var(--accent-dark));
      color: white;
      font-size: 1rem;
      font-weight: 800;
      cursor: pointer;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
      box-shadow: 0 12px 24px rgba(232, 77, 135, 0.28);
      margin-bottom: 18px;
    }

    button:hover {
      transform: translateY(-2px);
    }

    .result {
      margin-top: 4px;
      padding: 20px;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid rgba(255, 111, 161, 0.16);
      min-height: 92px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 6px;
    }

    .result small,
    .countdown small {
      color: #8a6270;
      font-weight: 600;
      letter-spacing: 0.02em;
    }

    .result strong {
      font-size: 2rem;
      color: var(--accent-dark);
    }

    .countdown {
      margin-top: 16px;
      padding: 18px;
      border-radius: 20px;
      background: rgba(255, 255, 255, 0.72);
      border: 1px solid rgba(255, 111, 161, 0.16);
    }

    .countdown-time {
      font-size: 1.55rem;
      font-weight: 800;
      color: var(--accent-dark);
      margin-top: 6px;
    }

    .footer {
      margin-top: 20px;
      font-size: 0.9rem;
      color: #8d6170;
    }

    .sparkle {
      font-size: 1.1rem;
    }

    @media (max-width: 520px) {
      .card {
        padding: 26px 18px;
        border-radius: 24px;
      }

      .result strong {
        font-size: 1.7rem;
      }

      .countdown-time {
        font-size: 1.35rem;
      }
    }
  </style>
</head>
<body>
  <div class="floating-hearts" aria-hidden="true">
    <div class="heart">💗</div>
    <div class="heart">💕</div>
    <div class="heart">💖</div>
    <div class="heart">💘</div>
    <div class="heart">💗</div>
    <div class="heart">💕</div>
  </div>

  <div class="card">
    <div class="badge">Per Flavietta 💕</div>
    <h1>Calcolatore orario di uscita</h1>
    <p class="subtitle">Inserisci l'orario di ingresso e scopri subito a che ora puoi uscire dal lavoro.</p>

    <div class="input-group">
      <label for="ingresso">Orario di ingresso</label>
      <input type="time" id="ingresso" required />
    </div>

    <button onclick="calcolaUscita()">Calcola l'orario di uscita ✨</button>

    <div class="result" id="risultato">
      <small>Il tuo orario comparirà qui</small>
      <strong>--:--</strong>
    </div>

    <div class="countdown" id="countdownBox">
      <small>Tempo rimanente all'uscita</small>
      <div class="countdown-time" id="countdown">--h --m --s</div>
    </div>

    <div class="footer">
      Calcolo basato su <strong>8 ore e 25 minuti</strong> di lavoro <span class="sparkle">🌷</span>
    </div>
  </div>

  <script>
    let countdownInterval = null;

    function calcolaUscita() {
      const input = document.getElementById('ingresso').value;
      const box = document.getElementById('risultato');
      const countdownEl = document.getElementById('countdown');

      if (!input) {
        box.innerHTML = '<small>Attenzione</small><strong style="font-size:1.2rem;">Inserisci un orario valido</strong>';
        countdownEl.textContent = '--h --m --s';
        if (countdownInterval) clearInterval(countdownInterval);
        return;
      }

      const [ore, minuti] = input.split(':').map(Number);
      const totaleMinutiIngresso = ore * 60 + minuti;
      const minutiDaAggiungere = 8 * 60 + 25;
      const totale = totaleMinutiIngresso + minutiDaAggiungere;

      const oreUscita = Math.floor((totale % (24 * 60)) / 60)
        .toString()
        .padStart(2, '0');
      const minutiUscita = (totale % 60)
        .toString()
        .padStart(2, '0');

      box.innerHTML = `
        <small>Flavietta può uscire alle</small>
        <strong>${oreUscita}:${minutiUscita}</strong>
      `;

      avviaCountdown(ore, minuti, minutiDaAggiungere);
    }

    function avviaCountdown(oreIngresso, minutiIngresso, minutiDaAggiungere) {
      const countdownEl = document.getElementById('countdown');
      const now = new Date();
      const uscita = new Date();

      uscita.setHours(oreIngresso, minutiIngresso, 0, 0);
      uscita.setMinutes(uscita.getMinutes() + minutiDaAggiungere);

      if (countdownInterval) clearInterval(countdownInterval);

      function aggiornaCountdown() {
        const adesso = new Date();
        let diff = uscita - adesso;

        if (diff <= 0) {
          countdownEl.textContent = 'Puoi uscireee 💖';
          clearInterval(countdownInterval);
          return;
        }

        const ore = Math.floor(diff / (1000 * 60 * 60));
        const minuti = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        const secondi = Math.floor((diff % (1000 * 60)) / 1000);

        countdownEl.textContent = `${String(ore).padStart(2, '0')}h ${String(minuti).padStart(2, '0')}m ${String(secondi).padStart(2, '0')}s`;
      }

      aggiornaCountdown();
      countdownInterval = setInterval(aggiornaCountdown, 1000);
    }

    document.getElementById('ingresso').addEventListener('keydown', function (e) {
      if (e.key === 'Enter') calcolaUscita();
    });
  </script>
</body>
</html>
